# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# User Authorization (comma-separated list of usernames and user IDs)
# Examples: "john_doe,123456789,jane_smith,987654321"
# Leave empty to allow all users
ALLOWED_USERS=

# Jira Configuration
JIRA_URL=https://myteam.aeroclub.ru
JIRA_USERNAME=your_jira_username
JIRA_API_TOKEN=your_jira_api_token

# Project Configuration
JIRA_PROJECT_KEY=AAI
JIRA_COMPONENT_NAME=org

# LLM Configuration (OPTIONAL, OpenAI-compatible endpoint)
# Used only as a fallback booster for assignee (assignee:/who:) guessing when
# transliteration + fuzzy matching don't find a match. If unset, guessing still
# works via fuzzy matching only.
# OPENAI_API_BASE=https://host:port/v1
# OPENAI_API_KEY=your_llm_api_key
# OPENAI_MODEL=unsloth/Qwen3-235B-A22B-Instruct-2507-GGUF
# LLM_ASSIGNEE_TIMEOUT=5
